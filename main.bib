	author = {Ferreira, Gabriela M. and Zanini, Natalie V. and De Menezes, Gabriela B. and Albertella, Lucy and Destree, Louise and Fontenelle, Leonardo F.},
	month = dec,
	year = {2018},
	pages = {360--374},
}

